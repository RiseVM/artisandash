# ===========================================
# Artisan Tile — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# Database (Required)
# Railway: auto-provisioned when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/artisan_tile

# Session (Required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-string

# Server
PORT=5000
NODE_ENV=development

# Admin Seed Account (first run only)
ADMIN_EMAIL=admin@artisantile.com
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@artisantile.com

# Client Portal
PORTAL_BASE_URL=https://your-app.up.railway.app/portal

# Google Drive — File Storage (optional)
# Service account JSON key (stringified) or path to key file
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id
