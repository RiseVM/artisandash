# Copy to .env and fill in values for local development.
# Required vars are marked REQUIRED; the rest have sensible defaults.

# ---- Server ----
NODE_ENV=development
PORT=5000

# Public URLs used in emails and contract links. If unset, the server falls
# back to the request's host header (fine for local dev).
APP_BASE_URL=http://localhost:5000
PORTAL_BASE_URL=http://localhost:5000/portal

# ---- Database (REQUIRED) ----
# Postgres connection string used by Drizzle.
DATABASE_URL=postgres://user:password@localhost:5432/artisandash

# ---- Sessions (REQUIRED) ----
# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ---- Admin seed ----
# Used once at first boot to create the initial admin account. In production
# the server refuses to seed without ADMIN_DEFAULT_PASSWORD set.
ADMIN_EMAIL=admin@artisantile.com
ADMIN_DEFAULT_PASSWORD=

# ---- Email (Resend) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=showroom@artisantile.com

# ---- Replit OIDC (only when deploying on Replit) ----
# REPL_ID, REPL_IDENTITY, REPL_SLUG, ISSUER_URL, REPLIT_CONNECTORS_HOSTNAME,
# WEB_REPL_RENEWAL are injected by the Replit runtime — leave unset locally.
